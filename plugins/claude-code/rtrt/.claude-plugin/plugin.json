{
  "name": "rtrt",
  "version": "0.1.0",
  "description": "Auto-capture coding-agent events into the rtrt memory store.",
  "hooks": {
    "PreToolUse":          "hooks/pre_tool_use.sh",
    "PostToolUse":         "hooks/post_tool_use.sh",
    "PostToolUseFailure":  "hooks/post_tool_use_failure.sh",
    "PreCompact":          "hooks/pre_compact.sh",
    "UserPromptSubmit":    "hooks/user_prompt_submit.sh",
    "PostUserPromptSubmit":"hooks/post_user_prompt_submit.sh",
    "Notification":        "hooks/notification.sh",
    "Stop":                "hooks/stop.sh",
    "SubagentStart":       "hooks/subagent_start.sh",
    "SubagentStop":        "hooks/subagent_stop.sh",
    "SessionStart":        "hooks/session_start.sh",
    "SessionEnd":          "hooks/session_end.sh"
  }
}
